# Copy this file to .env and fill in your values
# Never commit .env to version control

FLASK_ENV=development
PORT=5000

# PostgreSQL
DATABASE_URL=postgresql://urbanpulse:urbanpulse@localhost:5432/urbanpulse_dev

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT & App Secrets  (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# Email alerts (optional — SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
ALERT_FROM_EMAIL=alerts@urbanpulse.city
